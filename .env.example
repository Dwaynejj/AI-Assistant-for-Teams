# ========================
# Teams BI Agent — .env.example
#
# You do NOT need this file to try the app locally! Just run:
#   npm install && npm run dev
# and open http://localhost:3978 in your browser — the app boots in demo
# mode with mock data and no credentials required.
#
# Copy this file to .env and fill in real values ONLY when you're ready to
# connect a real CRM/ERP/Inventory system and/or deploy to Microsoft Teams
# and Azure (set NODE_ENV=production for that deployment).
# NEVER commit .env to version control.
# ========================

# ── Bot Identity (Azure Bot Registration) — required for Teams, not for the local web demo ──
MICROSOFT_APP_ID=<your-bot-app-id>
MICROSOFT_APP_PASSWORD=<your-bot-app-password>

# ── CRM System — leave unset to use built-in mock data ─────────────────────────
CRM_API_URL=https://your-crm.example.com/api
CRM_API_KEY=<crm-api-key>

# ── ERP System — leave unset to use built-in mock data ─────────────────────────
ERP_API_URL=https://your-erp.example.com/api
ERP_API_KEY=<erp-api-key>

# ── Inventory Database — leave unset to use built-in mock data ─────────────────
INVENTORY_DB_CONNECTION_STRING=<postgresql-or-mssql-connection-string>

# ── Force mock data on/off explicitly (overrides auto-detection above) ────────
# USE_MOCK_DATA=true

# ── Alert Thresholds ──────────────────────────────────────────────────────────
LOW_STOCK_THRESHOLD=50
CRITICAL_STOCK_THRESHOLD=10
PO_OVERDUE_DAYS=3

# ── Alert Channel Targets — required for Teams proactive alerts only ──────────
ALERT_TEAMS_CHANNEL_ID=<teams-channel-id>
ALERT_TEAMS_TEAM_ID=<teams-team-id>

# ── Azure Application Insights — optional locally; falls back to console logs ─
APPINSIGHTS_INSTRUMENTATIONKEY=<instrumentation-key>

# ── Azure Active Directory (RBAC Groups) — required for Teams/production only ─
AAD_TENANT_ID=<your-azure-tenant-id>
AAD_ROLE_GROUP_SALES=<aad-group-object-id-for-sales>
AAD_ROLE_GROUP_INVENTORY=<aad-group-object-id-for-inventory>
AAD_ROLE_GROUP_PROCUREMENT=<aad-group-object-id-for-procurement>
AAD_ROLE_GROUP_MANAGER=<aad-group-object-id-for-managers>
AAD_ROLE_GROUP_ADMIN=<aad-group-object-id-for-admins>

# ── Azure Key Vault (Optional — leave blank to use env vars directly) ─────────
KEY_VAULT_URL=https://your-keyvault.vault.azure.net/

# ── Azure AI Language (CLU / Language Detection) — optional, falls back to keyword matching ─
AZURE_LANGUAGE_ENDPOINT=https://your-language-resource.cognitiveservices.azure.com/
AZURE_LANGUAGE_KEY=<azure-language-api-key>
AZURE_CLU_PROJECT_NAME=TeamsBI-NLU
AZURE_CLU_DEPLOYMENT_NAME=production

# ── Application Settings ──────────────────────────────────────────────────────
# Set to "production" to deploy for real — this enables strict validation of
# every credential above. Anything else (including leaving this unset) runs
# in local demo mode with mock data and no required credentials.
NODE_ENV=development
PORT=3978
APP_VERSION=1.0.0
DEFAULT_LANGUAGE=en

# ── Bot Conversation Reference (for proactive messaging) ──────────────────────
BOT_SERVICE_URL=https://smba.trafficmanager.net/teams/
