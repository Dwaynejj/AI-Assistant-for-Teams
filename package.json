{
  "name": "teams-bi-agent",
  "version": "1.0.0",
  "description": "Microsoft Teams Business Intelligence Bot — bilingual EN/HE enterprise assistant",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc && node scripts/copyAssets.js",
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts",
    "test": "jest --runInBand",
    "lint": "eslint src/**/*.ts tests/**/*.ts --max-warnings 0",
    "lint:fix": "eslint src/**/*.ts tests/**/*.ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "audit:ci": "npm audit --audit-level=moderate",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "microsoft-teams",
    "bot",
    "business-intelligence",
    "crm",
    "erp",
    "inventory",
    "hebrew",
    "nlp"
  ],
  "author": "Teams BI Agent Team",
  "license": "MIT",
  "dependencies": {
    "@azure/ai-language-conversations": "^1.0.0-beta.1",
    "@azure/ai-language-text": "^1.1.0",
    "@azure/functions": "^3.5.1",
    "@azure/identity": "^4.4.1",
    "@azure/keyvault-secrets": "^4.8.0",
    "applicationinsights": "^2.9.5",
    "axios": "^1.6.8",
    "botbuilder": "^4.22.3",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.28",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
